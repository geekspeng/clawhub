# Convex 后端部署镜像
# 用于将 Convex 后端代码部署到 Convex Cloud
FROM oven/bun:1.3.10

WORKDIR /app

# 安装 Convex CLI
RUN bun install -g convex

# 复制项目配置文件和 workspaces
COPY package.json bun.lock ./
COPY packages ./packages

# 安装依赖（只安装生产环境和 Convex 相关的）
RUN bun install --frozen-lockfile --production

# 复制 Convex 后端代码
COPY convex ./convex
COPY tsconfig.json ./

# 复制部署脚本
COPY deploy-convex.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/deploy-convex.sh

# 设置工作目录
WORKDIR /app

# 默认执行部署脚本
CMD ["deploy-convex.sh"]
